# Per-clone local test configuration.
#
# Copy to `.env` (gitignored, auto-loaded by `just`) in each checkout you run
# tests from. The justfile derives every service port + URL from a single
# offset, so two clones running localnet/prover-backed tests never contend.
#
#   cp .env.example .env   # then pick a unique offset per clone
#
# Default clone leaves the offset at 0 (RPC 8899, photon 8784, prover 3001).
# A second clone might use 100 (RPC 8999, photon 8884, prover 3101), a third
# 200, and so on. Stay below ~900 to avoid colliding with the next service.
ZOLANA_PORT_OFFSET=0

# Explicit overrides (optional). Any of these win over the derived value above;
# set them only if you need a port/URL that does not follow the offset scheme.
# ZOLANA_LOCALNET_RPC_PORT=8899
# ZOLANA_LOCALNET_PHOTON_PORT=8784
# ZOLANA_LOCALNET_PROVER_PORT=3001
# ZOLANA_LOCALNET_URL=http://127.0.0.1:8899
# ZOLANA_LOCALNET_PHOTON_URL=http://127.0.0.1:8784
# ZOLANA_INDEXER_URL=http://127.0.0.1:8784
# ZOLANA_PROVER_URL=http://127.0.0.1:3001
