// Architecture diagram for docs/spec.md.
// Regenerate with `just render-diagrams` or:
//     dot -Tpng -Gdpi=144 docs/diagrams/architecture.dot -o docs/diagrams/architecture.png
//     dot -Tsvg          docs/diagrams/architecture.dot -o docs/diagrams/architecture.svg
//
// Client and RPC are both HTML-label tables with matching row heights so
// the cross arrows between corresponding ports are horizontal.
digraph G {
    compound=true;
    rankdir=LR;
    nodesep=0.3;
    ranksep=1.0;
    splines=line;
    bgcolor="#F8FAFC";
    node [shape=box, style="rounded,filled", fillcolor="#EEF2FF", color="#6366F1", fontcolor="#1E1B4B", fontname="Helvetica", fontsize=11, penwidth=1.2];
    edge [color="#475569", fontcolor="#334155", fontname="Helvetica", fontsize=10, penwidth=1.1];

    Client [shape=plaintext, label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="6" CELLPADDING="0" BGCOLOR="#EEF2FF" COLOR="#6366F1" STYLE="ROUNDED">
            <TR><TD HEIGHT="18" WIDTH="80"><FONT COLOR="#1E1B4B" POINT-SIZE="12"><B>Users</B></FONT></TD></TR>
            <TR><TD PORT="d" HEIGHT="32" WIDTH="80"></TD></TR>
            <TR><TD PORT="p" HEIGHT="32" WIDTH="80"></TD></TR>
            <TR><TD PORT="r" HEIGHT="32" WIDTH="80"></TD></TR>
            <TR><TD PORT="x" HEIGHT="32" WIDTH="80"></TD></TR>
        </TABLE>
    >];

    RPC [shape=plaintext, label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="6" CELLPADDING="0" BGCOLOR="#FFFFFF" COLOR="#CBD5E1" STYLE="ROUNDED">
            <TR><TD HEIGHT="18" WIDTH="128"><FONT COLOR="#0F172A" POINT-SIZE="12">RPC</FONT></TD></TR>
            <TR><TD PORT="d" HEIGHT="32" WIDTH="128" BGCOLOR="#EEF2FF" COLOR="#6366F1" STYLE="ROUNDED" BORDER="1"><FONT COLOR="#1E1B4B" POINT-SIZE="10">Photon Indexer</FONT></TD></TR>
            <TR><TD PORT="p" HEIGHT="32" WIDTH="128" BGCOLOR="#EEF2FF" COLOR="#6366F1" STYLE="ROUNDED" BORDER="1"><FONT COLOR="#1E1B4B" POINT-SIZE="10">Pocket RPC with auditor</FONT></TD></TR>
            <TR><TD PORT="r" HEIGHT="32" WIDTH="128" BGCOLOR="#EEF2FF" COLOR="#6366F1" STYLE="ROUNDED" BORDER="1"><FONT COLOR="#1E1B4B" POINT-SIZE="10">Prover</FONT></TD></TR>
            <TR><TD PORT="x" HEIGHT="32" WIDTH="128" BGCOLOR="#EEF2FF" COLOR="#6366F1" STYLE="ROUNDED" BORDER="1"><FONT COLOR="#1E1B4B" POINT-SIZE="10">Relayer</FONT></TD></TR>
        </TABLE>
    >];

    Forester [label="Forester"];

    // Solana is an HTML table. ROWSPAN ties the policy rows to a single SPP
    // cell on the right; the accounts span both columns below SPP.
    Solana [shape=plaintext, label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="6" CELLPADDING="0" BGCOLOR="#FFFFFF" COLOR="#CBD5E1" STYLE="ROUNDED">
            <TR><TD COLSPAN="3" HEIGHT="18"><FONT COLOR="#0F172A" POINT-SIZE="12">Solana</FONT></TD></TR>
            <TR>
                <TD PORT="passthru" COLSPAN="2" HEIGHT="32" WIDTH="130" BORDER="0"></TD>
                <TD ROWSPAN="4" PORT="spp" WIDTH="140" BGCOLOR="#EEF2FF" COLOR="#6366F1" STYLE="ROUNDED" BORDER="1"><FONT COLOR="#1E1B4B" POINT-SIZE="10">SPP<BR/>Shielded Pool Program</FONT></TD>
            </TR>
            <TR>
                <TD PORT="policy1" HEIGHT="32" WIDTH="110" BGCOLOR="#EEF2FF" COLOR="#6366F1" STYLE="ROUNDED" BORDER="1"><FONT COLOR="#1E1B4B" POINT-SIZE="10">Policy Program 1</FONT></TD>
                <TD HEIGHT="32" WIDTH="50"><FONT COLOR="#475569" POINT-SIZE="10">CPI &#x2192;</FONT></TD>
            </TR>
            <TR>
                <TD PORT="policy2" HEIGHT="32" WIDTH="110" BGCOLOR="#EEF2FF" COLOR="#6366F1" STYLE="ROUNDED" BORDER="1"><FONT COLOR="#1E1B4B" POINT-SIZE="10">Policy Program 2</FONT></TD>
                <TD HEIGHT="32" WIDTH="50"><FONT COLOR="#475569" POINT-SIZE="10">CPI &#x2192;</FONT></TD>
            </TR>
            <TR>
                <TD PORT="policyN" HEIGHT="32" WIDTH="110" BGCOLOR="#EEF2FF" COLOR="#6366F1" STYLE="ROUNDED" BORDER="1"><FONT COLOR="#1E1B4B" POINT-SIZE="10">Policy Program N</FONT></TD>
                <TD HEIGHT="32" WIDTH="50"><FONT COLOR="#475569" POINT-SIZE="10">CPI &#x2192;</FONT></TD>
            </TR>
            <TR>
                <TD COLSPAN="2" BORDER="0"></TD>
                <TD PORT="vault" HEIGHT="32" WIDTH="140" BGCOLOR="#E0F2FE" COLOR="#0284C7" STYLE="ROUNDED" BORDER="1"><FONT COLOR="#0C4A6E" POINT-SIZE="10">SPL interface vaults</FONT></TD>
            </TR>
            <TR>
                <TD COLSPAN="2" BORDER="0"></TD>
                <TD PORT="tree" HEIGHT="56" WIDTH="140" BGCOLOR="#E0F2FE" COLOR="#0284C7" STYLE="ROUNDED" BORDER="1"><FONT COLOR="#0C4A6E" POINT-SIZE="10">Tree accounts<BR/>UTXO tree<BR/>nullifier tree<BR/>nullifier queue</FONT></TD>
            </TR>
        </TABLE>
    >];

    // Client port -> matching RPC port. Same row heights on both tables
    // give horizontal arrows.
    Client:d:e -> RPC:d:w [dir=both, style=dashed, label="fetch encrypted UTXOs"];
    Client:p:e -> RPC:p:w [dir=both, style=dashed, label="fetch decrypted UTXOs"];
    Client:r:e -> RPC:r:w [dir=both, style=dashed, label="fetch proofs"];
    Client:x:e -> RPC:x:w [label="send transaction"];

    // Relayer can submit a tx directly to SPP (default pocket) or via one
    // of the Policy programs (policy pocket). The direct-to-SPP arrow enters
    // through the empty first-row cell so it doesn't cross any Policy box.
    RPC:x:ne -> Solana:spp:nw   [label="submit tx"];
    RPC:x:e -> Solana:policy1:w;

    // Forester processes the nullifier queue
    Forester -> Solana:tree:w [label="process nullifier queue"];
}
