# Copy to .env and fill in (auto-loaded by docker compose). `.env` is gitignored
# -- NEVER commit real secrets (RPC API keys, forester keypairs).

# --- Photon indexer ---
# Solana RPC that photon indexes (bring your own key).
PHOTON_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
# Initial backfill anchor slot; blank resumes from the DB's last-indexed slot.
PHOTON_START_SLOT=
# Expose photon off-box (default: localhost only). If 0.0.0.0, firewall it --
# photon has no auth of its own.
# PHOTON_BIND_ADDRESS=0.0.0.0

# --- Published images (pulled by default; override to point at your own) ---
# PHOTON_IMAGE=sergeytimoshin/zolana-photon:devnet
# PROVER_IMAGE=sergeytimoshin/zolana-prover:devnet
# FORESTER_IMAGE=sergeytimoshin/zolana-forester:devnet
# FORESTER_PROVER_IMAGE=sergeytimoshin/zolana-prover-forester:devnet

# --- Build photon from source (profile: build-photon; see README) ---
# Local photon (Rust) checkout current with this repo.
# PHOTON_BUILD_CONTEXT=../../photon

# --- Prover concurrency tuning (soak/bench) ---
# PROVER_MAX_CONCURRENCY=4
# Optional total-memory budget used by the prover's concurrency limiter.
# PROVER_TOTAL_MEMORY_GB=16

# --- Client prover exposure (TEMPORARY: witnesses cross the wire in plaintext) ---
# Only expose off-box for a trusted/temporary setup, and firewall the port.
# PROVER_BIND_ADDRESS=127.0.0.1
# PROVER_PORT=3011

# --- Forester prover (profile: forester) ---
# Internal by default (127.0.0.1); reached as forester-prover:3001. Its image
# bakes the batch address-append key, so no key volume or GitHub token is needed.
# FORESTER_PROVER_BIND_ADDRESS=127.0.0.1
# FORESTER_PROVER_PORT=3002

# --- Forester (profile: forester) ---
# Gated behind the `forester` profile, so a plain `up` never starts it and none
# of these vars are required. WIP: the binary reads none of them yet (scaffolding
# for the continuous nullifier-tree worker). Left optional until the worker
# enforces them.
# Forester smart-account settings pubkey; the vault at FORESTER_ACCOUNT_INDEX is
# the tree's forester_authority.
# FORESTER_SETTINGS=
# FORESTER_ACCOUNT_INDEX=0
# Pool tree to maintain (defaults to the SPP devnet tree).
# FORESTER_TREE=treeYbr45LjxovKvtD46uEphM64kwoFFPYhVNw1A8x8
# A member keypair of the forester smart account (JSON byte array); signs + pays.
# FORESTER_PAYER=[...]
