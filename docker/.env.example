# Copy to .env and fill in. Auto-loaded by docker compose (same dir as
# docker-compose.yml / docker-compose.remote.yml). `.env` is gitignored --
# NEVER commit real secrets (RPC API keys, forester keypairs).

# --- Photon indexer ---
# Solana RPC that photon indexes (bring your own key).
PHOTON_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
# Initial backfill anchor: the slot the shielded-pool program was deployed at.
# Leave blank (PHOTON_START_SLOT=) to resume from the DB's last-indexed slot.
PHOTON_START_SLOT=
# Expose photon off-box (default: localhost only). If set to 0.0.0.0, put it
# behind a firewall / TLS -- photon has no auth of its own.
# PHOTON_BIND_ADDRESS=0.0.0.0

# --- Published images ---
# docker-compose.yml PULLS the published photon image by default
# (PHOTON_IMAGE defaults to sergeytimoshin/zolana-photon:devnet in-compose), so
# no local photon checkout is needed to `up` the stack. Override to point at
# images you publish via docker-bake.hcl (set REGISTRY when baking).
# PHOTON_IMAGE=sergeytimoshin/zolana-photon:devnet
# PROVER_IMAGE=<registry>/zolana-prover:devnet
# FORESTER_IMAGE=<registry>/zolana-forester:devnet
# FORESTER_PROVER_IMAGE=<registry>/zolana-prover-forester:devnet

# --- Build photon from source (docker-compose.yml, profile: build-photon) ---
# Opt-in only. Point PHOTON_BUILD_CONTEXT at a local photon (Rust) checkout that
# is current with this repo, then build + tag the image and bring the stack up:
#   PHOTON_BUILD_CONTEXT=../photon PHOTON_IMAGE=zolana-photon:local \
#     docker compose -f docker/docker-compose.yml --profile build-photon build photon-build
#   PHOTON_IMAGE=zolana-photon:local docker compose -f docker/docker-compose.yml up -d
# PHOTON_BUILD_CONTEXT=../photon

# Prover concurrency tuning (soak/bench). TRANSFER_WORKER_CONCURRENCY caps
# concurrent transfer proofs the queue worker runs; empty falls back to
# PROVER_MAX_CONCURRENCY, then a conservative default.
# TRANSFER_WORKER_CONCURRENCY=4
# PROVER_MAX_CONCURRENCY=4

# --- Client prover exposure (TEMPORARY: witnesses cross the wire in plaintext) ---
# Only expose off-box for a trusted/temporary setup, and firewall the port.
# PROVER_BIND_ADDRESS=127.0.0.1
# PROVER_PORT=3011

# --- Forester prover (docker-compose.remote.yml, profile: forester) ---
# FORESTER_PROVER_BIND_ADDRESS=127.0.0.1
# FORESTER_PROVER_PORT=3002
# The zolana-prover-forester image bakes in the batch address-append key
# matching the on-chain vkey, so no key volume or GitHub token is needed here.

# --- Forester (profile: forester) ---
# The `run` worker submits batch_update_nullifier_tree through a Squads
# smart-account vault (the tree's forester_authority), consistent with the SPP's
# other protocol authorities.
# Forester smart-account settings pubkey (required for `run`); the vault at
# FORESTER_ACCOUNT_INDEX is the tree's forester_authority.
# FORESTER_SETTINGS=
# FORESTER_ACCOUNT_INDEX=0
# Pool tree to maintain (defaults to the SPP devnet tree).
# FORESTER_TREE=treeYbr45LjxovKvtD46uEphM64kwoFFPYhVNw1A8x8
# A member keypair of the forester smart account as a JSON byte array; signs the
# execute + pays fees. Required to submit; `forester info` works without it.
# FORESTER_PAYER=[...]
